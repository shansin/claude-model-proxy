# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# Map Claude model tiers to Ollama models
# Any model name containing "opus" will use this
OLLAMA_MODEL_MAP_OPUS=qwen3.5:27b

# Any model name containing "sonnet" will use this
OLLAMA_MODEL_MAP_SONNET=qwen3.5:27b

# Any model name containing "haiku" will use this
OLLAMA_MODEL_MAP_HAIKU=qwen3.5:27b

# Fallback when no tier matches
OLLAMA_MODEL_MAP_DEFAULT=qwen3.5:27b